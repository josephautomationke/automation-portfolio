    {
      "parameters": {
        "jsCode": "// 1. Get AI text from correct path\nlet rawText = $json.output?.[0]?.content?.[0]?.text;\n\nif (!rawText) {\n  throw new Error(\"AI text output not found\");\n}\n\n// 2. CLEAN the AI output (remove ```json wrappers)\nrawText = rawText\n  .replace(/```json/g, \"\")\n  .replace(/```/g, \"\")\n  .trim();\n\n// 3. Parse cleaned JSON\nlet parsed;\ntry {\n  parsed = JSON.parse(rawText);\n} catch (e) {\n  throw new Error(\"AI output is not valid JSON after cleaning\");\n}\n\n// 4. Return proper n8n structure\nreturn [\n  {\n    json: parsed\n  }\n];"
      },
